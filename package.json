{
  "name": "codex-app-server-ts",
  "version": "0.1.0",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "generate": "bunx @openai/codex app-server generate-ts --out ./schemas",
    "build": "bun run --bun tsdown",
    "typecheck": "tsc --noEmit",
    "example": "bun run ./example.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsdown": "^0.11",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
